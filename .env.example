# PortalAdmin — Dashboard + cruscotto JLO/ADMIN
# Copia questo file in .env e compila i valori.

# ── Server cruscotto ─────────────────────────────────────────────
# HOME selettore progetti (multi-istanza)
PORTAL_HOME_PORT=3990
# Porta default singolo cruscotto (override per overlay: PRJ_DASHBOARD_PORT in project.config)
DASHBOARD_PORT=3999

# ── Product repo — ADMIN-90 ───────────────────────────────────────
# Default: sibling ../{PRJ_REPO} da overlay project.config attivo (vedi PRJ_NAME)
# Nuovo product: PROJECT_{PRJ_NAME}/project.config.{PRJ_NAME}.mjs
#   + PROJECT_{PRJ_NAME}/runner.config.{PRJ_NAME}.mjs
#   + PROJECT_{PRJ_NAME}/discovery.config.{PRJ_NAME}.mjs
PRODUCT_REPO_PATH=

# Overlay attivo — obbligatorio (nessun default in codice)
PRJ_NAME=JustLastOne
# PRJ_NAME=PortalAdmin   # tooling ADMIN — richiede overlay PROJECT_PortalAdmin completi

# ── Servizi stack (health check tab Servizi + runner test) ───────
AUTH_URL=http://localhost:4001/api/v1
API_URL=http://localhost:4000/api/v1
WEB_BASE=http://localhost:3000

# ── Cruscotto SQLite backlog Jira (ADMIN-81 / ADMIN-99) ─────────
# Default: PROJECT_{PRJ_NAME}/cruscotto_{PRJ_NAME}.db (es. PROJECT_JustLastOne/cruscotto_JustLastOne.db)
CRUSCOTTO_DB_PATH=

# ── Cursor Agent SDK (tab Cursor Agent nel cruscotto) ───────────
# API key: https://cursor.com/dashboard/integrations
CURSOR_API_KEY=
# Runtime default: local | cloud
CURSOR_AGENT_DEFAULT_RUNTIME=local
# Modello (es. composer-2.5, auto)
CURSOR_AGENT_MODEL=composer-2.5
# Override cwd agent local (default: PRODUCT_REPO_PATH)
# CURSOR_AGENT_LOCAL_CWD=
# Repo GitHub per cloud (virgola); default PortalAdmin + JustLastOne
# CURSOR_CLOUD_REPOS=https://github.com/IbyEll/PortalAdmin,https://github.com/IbyEll/JustLastOne
# CURSOR_CLOUD_AUTO_PR=1

# ── Jira ─────────────────────────────────────────────────────────
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_CLOUD_ID=3caddd74-469e-4ca3-adf8-926f79c98e7c
JIRA_BOARD_ID=68
JIRA_SITE=myfuturejobsearch.atlassian.net
