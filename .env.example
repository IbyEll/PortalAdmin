# PortalAdmin — Dashboard + cruscotto JLO/ADMIN
# Copia questo file in .env e compila i valori.

# ── Server cruscotto ─────────────────────────────────────────────
DASHBOARD_PORT=3999

# ── Product repo (JustLastOne) — ADMIN-90 ───────────────────────
# Default: sibling ../JustLastOne (se checkout affiancato)
PRODUCT_REPO_PATH=

# ── Servizi stack (health check tab Servizi + runner test) ───────
AUTH_URL=http://localhost:4001/api/v1
API_URL=http://localhost:4000/api/v1
WEB_BASE=http://localhost:3000

# ── Jira ─────────────────────────────────────────────────────────
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_CLOUD_ID=3caddd74-469e-4ca3-adf8-926f79c98e7c
JIRA_BOARD_ID=68
JIRA_SITE=myfuturejobsearch.atlassian.net
