generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("CRUSCOTTO_DATABASE_URL")
}

/// Snapshot Jira sync job (Admin cruscotto cache).
model SyncRun {
  id          String    @id @default(uuid())
  startedAt   DateTime  @default(now()) @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  source      String    @default("jira-api")
  issueCount  Int       @default(0) @map("issue_count")
  status      String

  issues             JiraIssue[]
  wipIssues          JiraIssueWip[]
  workingPlanSprints WorkingPlanSprintKeys[]
  matrixRuns         MatrixRun[]

  @@map("sync_run")
}

/// Issue row aligned with JiraBacklogRow ( /lib/jira/jira.backlog.mjs).
model JiraIssue {
  id                String    @id @default(uuid())
  jiraKey           String    @unique @map("jira_key")
  issueType         String    @map("issue_type")
  summary           String
  status            String
  statusCategory    String?   @map("status_category")
  parentJiraKey     String?   @map("parent_jira_key")
  jiraUpdatedAt     DateTime? @map("jira_updated_at")
  tier              String
  isStoryLike       Boolean   @default(false) @map("is_story_like")
  isDone            Boolean   @default(false) @map("is_done")
  depth             Int       @default(0)
  hasChildren       Boolean   @default(false) @map("has_children")
  devOrder          String?   @map("dev_order")
  devSprint         Int?      @map("dev_sprint")
  devSprintName     String?   @map("dev_sprint_name")
  devSort           Int?      @map("dev_sort")
  isObsolete        Boolean   @default(false) @map("is_obsolete")
  relatedKeys       String?   @map("related_keys")
  rawFields         String?   @map("raw_fields")
  syncRunId         String    @map("sync_run_id")
  syncedAt          DateTime  @default(now()) @map("synced_at")

  syncRun   SyncRun           @relation(fields: [syncRunId], references: [id], onDelete: Cascade)
  sprints   JiraIssueSprint[]
  linksFrom JiraIssueLink[]   @relation("LinkFrom")
  linksTo   JiraIssueLink[]   @relation("LinkTo")

  @@index([syncRunId])
  @@index([parentJiraKey])
  @@map("jira_issue")
}

/// Coda WIP — story + issue da elaborare (stessa struttura di JiraIssue).
model JiraIssueWip {
  id                String    @id @default(uuid())
  jiraKey           String    @unique @map("jira_key")
  issueType         String    @map("issue_type")
  summary           String
  status            String
  statusCategory    String?   @map("status_category")
  parentJiraKey     String?   @map("parent_jira_key")
  jiraUpdatedAt     DateTime? @map("jira_updated_at")
  tier              String
  isStoryLike       Boolean   @default(false) @map("is_story_like")
  isDone            Boolean   @default(false) @map("is_done")
  depth             Int       @default(0)
  hasChildren       Boolean   @default(false) @map("has_children")
  devOrder          String?   @map("dev_order")
  devSprint         Int?      @map("dev_sprint")
  devSprintName     String?   @map("dev_sprint_name")
  devSort           Int?      @map("dev_sort")
  isObsolete        Boolean   @default(false) @map("is_obsolete")
  relatedKeys       String?   @map("related_keys")
  rawFields         String?   @map("raw_fields")
  syncRunId         String    @map("sync_run_id")
  syncedAt          DateTime  @default(now()) @map("synced_at")

  syncRun SyncRun @relation(fields: [syncRunId], references: [id], onDelete: Cascade)

  @@index([syncRunId])
  @@index([parentJiraKey])
  @@map("jira_issue_wip")
}

model JiraSprint {
  id        Int       @id
  name      String
  state     String
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")

  issues JiraIssueSprint[]

  @@map("jira_sprint")
}

model JiraIssueSprint {
  issueId  String @map("issue_id")
  sprintId Int    @map("sprint_id")

  issue  JiraIssue  @relation(fields: [issueId], references: [id], onDelete: Cascade)
  sprint JiraSprint @relation(fields: [sprintId], references: [id], onDelete: Cascade)

  @@id([issueId, sprintId])
  @@map("jira_issue_sprint")
}

model JiraIssueLink {
  id          String @id @default(uuid())
  fromIssueId String @map("from_issue_id")
  toIssueId   String @map("to_issue_id")
  linkType    String @map("link_type")

  fromIssue JiraIssue @relation("LinkFrom", fields: [fromIssueId], references: [id], onDelete: Cascade)
  toIssue   JiraIssue @relation("LinkTo", fields: [toIssueId], references: [id], onDelete: Cascade)

  @@index([fromIssueId])
  @@index([toIssueId])
  @@map("jira_issue_link")
}

model WorkingPlanSprintKeys {
  planSprintName String @id @map("plan_sprint_name")
  issueKeys      String @map("issue_keys")
  syncRunId      String @map("sync_run_id")

  syncRun SyncRun @relation(fields: [syncRunId], references: [id], onDelete: Cascade)

  @@map("working_plan_sprint_keys")
}

/// Epic di riferimento impostata manualmente per story senza parent epic in Jira.
model JiraIssueEpicRef {
  jiraKey     String   @id @map("jira_key")
  epicJiraKey String   @map("epic_jira_key")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([epicJiraKey])
  @@map("jira_issue_epic_ref")
}

/// Snapshot run matrice (portal_gap, test_coverage, …).
model MatrixRun {
  id          String    @id @default(uuid())
  matrixKind  String    @map("matrix_kind")
  generatedAt DateTime  @default(now()) @map("generated_at")
  source      String
  metricsJson String?   @map("metrics_json")
  syncRunId   String?   @map("sync_run_id")

  syncRun SyncRun?          @relation(fields: [syncRunId], references: [id], onDelete: SetNull)
  rows    MatrixRow[]
  events  MatrixRowEvent[]

  @@index([matrixKind])
  @@index([syncRunId])
  @@map("matrix_run")
}

/// Definizioni stabili catalogo matrice (seed da AUDIT_CATALOG).
model MatrixCatalog {
  findingId      String  @id @map("finding_id")
  matrixKind     String  @map("matrix_kind")
  sectionId      String  @map("section_id")
  defaultVoce    String? @map("default_voce")
  scanIdsJson    String? @map("scan_ids_json")
  auditEntryJson String? @map("audit_entry_json")

  @@index([matrixKind])
  @@index([sectionId])
  @@map("matrix_catalog")
}

/// Stato corrente riga matrice per finding_id.
model MatrixRow {
  findingId    String   @map("finding_id")
  matrixKind   String   @map("matrix_kind")
  matrixRunId  String   @map("matrix_run_id")
  sectionId    String?  @map("section_id")
  status       String
  sev          String?
  project      String?
  voce         String?
  dettaglio    String?
  pathsJson    String?  @map("paths_json")
  resolvedNote String?  @map("resolved_note")
  contentSig   String?  @map("content_sig")
  firstSeenAt  DateTime @default(now()) @map("first_seen_at")
  lastSeenAt   DateTime @default(now()) @map("last_seen_at")

  matrixRun    MatrixRun           @relation(fields: [matrixRunId], references: [id], onDelete: Cascade)
  events       MatrixRowEvent[]
  findingIssue MatrixFindingIssue?

  @@id([findingId, matrixKind])
  @@index([matrixRunId])
  @@index([status])
  @@map("matrix_row")
}

/// Storico append-only eventi riga matrice.
model MatrixRowEvent {
  id          String   @id @default(uuid())
  findingId   String   @map("finding_id")
  matrixKind  String   @map("matrix_kind")
  matrixRunId String   @map("matrix_run_id")
  at          DateTime @default(now())
  eventType   String   @map("event_type")
  oldStatus   String?  @map("old_status")
  newStatus   String?  @map("new_status")
  note        String?

  matrixRun MatrixRun @relation(fields: [matrixRunId], references: [id], onDelete: Cascade)
  matrixRow MatrixRow @relation(fields: [findingId, matrixKind], references: [findingId, matrixKind], onDelete: Cascade)

  @@index([findingId, matrixKind])
  @@index([matrixRunId])
  @@map("matrix_row_event")
}

/// Link finding matrice ↔ ticket Jira (sostituisce matrix.finding-issues.json).
model MatrixFindingIssue {
  findingId    String   @map("finding_id")
  matrixKind   String   @map("matrix_kind")
  jiraKey      String   @unique @map("jira_key")
  issueType    String?  @map("issue_type")
  linkedAt     DateTime @default(now()) @map("linked_at")
  linkedSource String?  @map("linked_source")

  matrixRow MatrixRow @relation(fields: [findingId, matrixKind], references: [findingId, matrixKind], onDelete: Cascade)

  @@id([findingId, matrixKind])
  @@map("matrix_finding_issue")
}
