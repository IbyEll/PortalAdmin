{

  "requirements": {

    "nodeMin": "20",

    "stack": [

      { "app": "web", "label": "Web", "tech": "Next.js 15" },

      { "app": "api", "label": "API", "tech": "NestJS" },

      { "app": "auth", "label": "Auth", "tech": "NestJS" },

      { "app": "database", "label": "Database", "tech": "Prisma + SQLite" },

      { "app": "monorepo", "label": "Monorepo", "tech": "Turbo" }

    ],

    "prerequisites": [

      "Node.js >= 20",

      "npm",

      "SQLite (via Prisma)"

    ],

    "envFiles": [

      { "path": ".env", "label": "PortalAdmin / Cruscotto" },

      { "path": "packages/database/.env", "label": "Database" },

      { "path": "apps/api/.env", "label": "API" },

      { "path": "apps/authentication/.env", "label": "Auth" },

      { "path": "apps/web/.env", "label": "Web" }

    ],

    "commands": [

      { "id": "install", "label": "Installa dipendenze", "cmd": "npm install" },

      { "id": "db-setup", "label": "Setup database", "cmd": "npm run db:setup" },

      { "id": "dev", "label": "Avvia stack dev", "cmd": "npm run dev" },

      { "id": "start-dev", "label": "Avvia product (PortalAdmin)", "cmd": "npm run start:dev" },

      { "id": "start-dev-clean", "label": "Solo cleanup artefatti", "cmd": "node ellaStartScript/start-dev.mjs --clean-only" },

      { "id": "start-dev-db-reset", "label": "Reset DB SQLite + seed", "cmd": "node ellaStartScript/init_Database_DEV.mjs --reset --seed" },

      { "id": "seed-data", "label": "Alimentazione dati test", "cmd": "node ellaStartScript/run-data-seeds.mjs --seed func --wait-auth" },

      { "id": "dashboard", "label": "Avvia cruscotto PortalAdmin", "cmd": "npm run admin:dashboard" }

    ],

    "readmeUrl": "README.md"

  },

  "services": [

    {

      "id": "web",

      "label": "Web",

      "description": "Frontend Next.js 15 — UI prodotto IT/EN",

      "port": 3000,

      "healthUrl": "http://localhost:3000/it",

      "openUrl": "http://localhost:3000/it",

      "docs": null

    },

    {

      "id": "api",

      "label": "API",

      "description": "API REST NestJS — dominio applicativo",

      "port": 4000,

      "healthUrl": "http://localhost:4000/api/v1/health",

      "openUrl": "http://localhost:4000/api/v1/docs",

      "docs": "/docs"

    },

    {

      "id": "auth",

      "label": "Auth",

      "description": "API auth NestJS — login, JWT, registrazione",

      "port": 4001,

      "healthUrl": "http://localhost:4001/api/v1/health",

      "openUrl": "http://localhost:4001/api/v1/docs",

      "docs": "/docs"

    },

    {

      "id": "dashboard",

      "label": "Admin Dashboard",

      "description": "Cruscotto dev — test, report, utility",

      "port": 3999,

      "healthUrl": "http://localhost:3999/api/health",

      "openUrl": "http://localhost:3999/",

      "docs": null

    },

    {

      "id": "api-portal",

      "label": "API Portal",

      "description": "Navigazione OpenAPI centralizzata — PortalAdmin, config da PRODUCT_REPO_PATH",

      "port": 4080,

      "healthUrl": "http://localhost:4080/",

      "openUrl": "http://localhost:4080/",

      "docs": null

    },

    {

      "id": "friendbot",

      "label": "friendBOT JLO",

      "description": "Daemon dev — amicizie e risposte chat automatiche",

      "processScript": "testScript/funzionali/friend-bot.mjs",

      "start": {

        "type": "node",

        "script": "testScript/funzionali/friend-bot.mjs"

      }

    }

  ]

}


