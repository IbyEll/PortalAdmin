{
  "name": "portal-admin"
, "version": "0.1.0"
, "private": true
, "type": "module"
, "description": "PortalAdmin — Admin Dashboard estratto da JustLastOne (epic ADMIN-88)"
, "engines": {
    "node": ">=20"
  }
, "scripts": {
    "admin:dashboard": "node server/dashboard-server.mjs"
  , "start:dev": "node runner/start-dev.mjs"
  , "dev:prepare": "node runner/start-dev.mjs --prepare-only"
  , "dev:db": "node lib/cruscotto-db/script_seed/init_Database_DEV.mjs --push"
  , "dev:seed-data": "node lib/cruscotto-db/script_seed/run-data-seeds.mjs"
  , "dev:api-auth": "node runner/start_DEV_Service.mjs auth"
  , "dev:api-project": "node runner/start_DEV_Service.mjs api"
  , "dev:api-portal": "node runner/start_API_Portal.mjs"
  , "dev:web": "node runner/start_DEV_Service.mjs web"
  , "dev:all": "node runner/start_ALL_Services.mjs"
  , "db:migrate": "node lib/cruscotto-db/migrate.mjs"
  , "db:sync": "node scripts/sync-jira-backlog.mjs"
  , "test:paths": "node scripts/smoke-portal-paths.mjs"
  , "test:run-all": "node scripts/smoke-run-all.mjs"
  , "test:config": "node scripts/smoke-portal-config.mjs"
  , "test:workflow": "node scripts/smoke-workflow.mjs"
  , "test:dashboard": "node scripts/smoke-dashboard.mjs"
  , "test:cruscotto-db": "node scripts/smoke-cruscotto-db.mjs"
  , "test:portal-e2e": "node scripts/smoke-portal-e2e.mjs"
  , "test:ci": "node scripts/smoke-ci.mjs"
  , "start:all": "node runner/start_ALL_Services.mjs"
  , "stop:all": "node runner/stop_ALL_services.mjs"
  }
, "dependencies": {
    "dotenv": "^16.4.7"
  , "@prisma/client": "^6.9.0"
  , "exceljs": "^4.4.0"
  }
}
