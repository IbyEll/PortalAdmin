# Dependencies
node_modules/

# Local env (never commit secrets)
.env
.env.local
.env.*.local

# Generated report HTML/JSON (run-all, export)
cruscotto.frontend/reports/

# Generated data (SQLite, exports, runtime state)
cruscotto.database/*
!cruscotto.database/.gitkeep
!cruscotto.database/prisma/
!cruscotto.database/prisma/**
!cruscotto.database/script_seed/
!cruscotto.database/script_seed/**
!cruscotto.database/cruscotto.db.config.mjs
!cruscotto.database/migrate.mjs
!cruscotto.database/load-backlog.mjs
!cruscotto.database/Jira.backlog.sync.mjs
!cruscotto.database/package.json
!cruscotto.database/package-lock.json

# Cruscotto backlog SQLite per overlay PROJECT_*
PROJECT_*/cruscotto_*.db
PROJECT_*/cruscotto_*.db-journal

# Legacy data/ (deprecato — usare cruscotto.database/)
data/*
!data/.gitkeep

# OS / editor
admin.portal/.cursor-agent-job.*.json
admin.portal/cursor.agent.runtime.state.json
.DS_Store
Thumbs.db
desktop.ini
*.log
